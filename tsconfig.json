{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": ["index.ts", "db.ts", "lib/**/*.ts", "routes/**/*.ts"],
  "exclude": ["node_modules", "dist", "vite.ts", "storage.ts", "shared"]
}

